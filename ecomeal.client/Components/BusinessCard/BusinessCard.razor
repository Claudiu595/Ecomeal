@namespace Ecomeal.Site.Components.BusinessCard

<style>
    .delete-btn {
        background-color: #dc3545;
        color: white;
        border: 1px solid #dc3545;
        transition: all 0.2s ease-in-out;
    }

    .delete-btn:hover {
        background-color: white;
        color: #dc3545;
        border-color: #dc3545;
    }
</style>

<div class="card h-100 shadow-sm border-0" @onclick = "NavigateToDetails">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <h5 class="card-title fw-semibold mb-0">@Business.Name</h5>
            <span class="badge bg-success-subtle text-success">@Business.BusinessTypeName</span>
        </div>

        <p class="card-text text-muted flex-grow-1">@Business.Description</p>

        <ul class="list-unstyled mb-4 small text-secondary">
            <li><strong>Address:</strong> @Business.Adress</li>
            <li><strong>Contact:</strong> @Business.Contact</li>
        </ul>

        <button class="btn btn-danger btn-sm mt-auto align-self-end delete-btn"
                @onclick="DeleteClick">
            Delete
        </button>
    </div>
</div>