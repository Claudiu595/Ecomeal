@page "/business-list"
@using EcoMeal.Site.Components.BusinessCard
@namespace EcoMeal.Client.Components.BusinessList

@if (Businesses == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        @foreach (var business in Businesses)
        {
            <MudItem xs="12" md="4">
                <BusinessCard Business="business" OnDeleteRequested="HandleDelete" />

            </MudItem>
        }
    </MudGrid>
}