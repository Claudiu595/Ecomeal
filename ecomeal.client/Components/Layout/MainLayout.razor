@inherits LayoutComponentBase
@namespace EcoMeal.Client.Components.Layout
@inject SearchService SearchService

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Style="background: linear-gradient(90deg, #35c022 0%, #92a433 100%); height: 70px; padding: 0 20px;">
        <MudButton Href="/" Style="color: white; text-transform: none; padding: 0;">
            <MudText Typo="Typo.h5" Style="font-weight: 700;">EcoMeal</MudText>
        </MudButton>
        
        <MudSpacer />

        <div style="width: 250px;">
            <MudTextField T="string" 
                          Placeholder="Caută..." 
                          Variant="Variant.Outlined" 
                          Margin="Margin.Dense"
                          Class="bg-white rounded-lg"
                          Style="height: 40px;"
                          Value="@SearchService.SearchTerm"
                          ValueChanged="@((string val) => SearchService.UpdateSearch(val))"
                          Immediate="true" />
        </div>
    </MudAppBar>

    <MudMainContent>
        <div class="container-fluid px-4 mt-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>