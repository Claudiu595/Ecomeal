@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
    <div class="container-fluid px-3 px-lg-4">
        <a class="navbar-brand me-3" href="">
            <span class="brand-title">Eco Meal</span>
        </a>

        <form class="d-flex flex-grow-1 mx-lg-4 my-2 my-lg-0" @onsubmit:preventDefault="true">
            <input class="form-control" type="search" placeholder="Search businesses..." aria-label="Search businesses" value="@SearchTerm" @oninput="OnSearchChanged" />
        </form>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="mainNav">
            <ul class="navbar-nav align-items-lg-center">
                <li class="nav-item">
                    <div class="nav-home-link" aria-label="Home">
                        <img src="/Netrom.png?v=2" alt="Home" class="nav-home-image" />
                    </div>
                </li>
            </ul>
        </div>
    </div>
</nav>

@code {
    private string SearchTerm { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        SearchTerm = GetSearchTerm();
    }

    protected override void OnParametersSet()
    {
        SearchTerm = GetSearchTerm();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        SearchTerm = e.Value?.ToString() ?? string.Empty;
        NavigationManager.NavigateTo(NavigationManager.GetUriWithQueryParameter("search", SearchTerm));
    }

    private string GetSearchTerm()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("search", out var value) ? value.ToString() ?? string.Empty : string.Empty;
    }
}

