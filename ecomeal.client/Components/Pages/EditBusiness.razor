@page "/business/{Id:int}/edit"
@using EcoMeal.Client.Models
@using EcoMeal.Client.Services
@using MudBlazor

<PageTitle>Editare Afacere</PageTitle>

<style>
    .solid-dropdown-popover {
        background-color: #ffffff !important;
        border: 1px solid #e0e0e0;
        box-shadow: 0px 4px 12px rgba(0,0,0,0.15) !important;
    }
    .solid-dropdown-popover .mud-list-item-text {
        color: #212529 !important;
    }
    .solid-dropdown-popover .mud-list-item:hover {
        background-color: #f1f1f1 !important;
    }
</style>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
}

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               Style="text-transform: none; color: #000; font-weight: 600; margin-bottom: 1rem;"
               OnClick="NavigateBack">
        Înapoi la afacere
    </MudButton>

    @if (IsLoading)
    {
        <MudPaper Class="pa-8 rounded-xl d-flex justify-center" Elevation="0" Style="border: 1px solid #f0f0f0;">
            <MudProgressCircular Indeterminate="true" Color="MudBlazor.Color.Dark" />
        </MudPaper>
    }
    else if (Model is null && string.IsNullOrEmpty(ErrorMessage))
    {
        <MudAlert Severity="Severity.Warning">Afacerea nu a fost găsită.</MudAlert>
    }
    else if (Model is not null)
    {
        <MudPaper Class="pa-8 rounded-xl" Elevation="0" Style="border: 1px solid #f0f0f0;">
            <MudText Typo="Typo.h5" Style="font-weight: 800; margin-bottom: 0.5rem;">Editare Afacere</MudText>
            <MudText Typo="Typo.body2" Style="color: #6b7280; margin-bottom: 2rem;">Actualizează detaliile afacerii mai jos.</MudText>

            <EditForm Model="Model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="Model.Name"
                              Label="Nume Afacere"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Required="true"
                              RequiredError="Numele este obligatoriu" />

                <MudTextField @bind-Value="Model.Address"
                              Label="Adresă"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Required="true"
                              RequiredError="Adresa este obligatorie" />

                <MudTextField @bind-Value="Model.Description"
                              Label="Descriere"
                              Variant="Variant.Outlined"
                              Lines="3"
                              Class="mb-4" />

                <MudTextField @bind-Value="Model.Contact"
                              Label="Contact"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Required="true"
                              RequiredError="Contactul este obligatoriu" />

                <MudSelect @bind-Value="Model.BusinessTypeId"
                           Label="Tip Afacere"
                           Variant="Variant.Outlined"
                           Class="mb-6"
                           Required="true"
                           RequiredError="Te rog selectează un tip de afacere"
                           AnchorOrigin="Origin.BottomCenter"
                           PopoverClass="solid-dropdown-popover">
                @if (BusinessTypes is not null)
                {
                    @foreach (var type in BusinessTypes)
                    {
                        <MudSelectItem Value="type.Id">@type.Name</MudSelectItem>
                    }
                }
                </MudSelect>

                <MudStack Row="true" Spacing="3">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Style="background: #000; color: #fff; text-transform: none; font-weight: 700; flex: 1;"
                               Size="MudBlazor.Size.Large">
                        Salvează Modificările
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Style="text-transform: none; font-weight: 600;"
                               Size="MudBlazor.Size.Large"
                               OnClick="HandleDelete">
                        Șterge
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    [Inject]
    public required BusinessService BusinessService { get; set; }
    
    [Inject]
    public required NavigationManager NavigationManager { get; set; }

    private BusinessAddModel? Model;
    private List<BusinessTypeModel>? BusinessTypes;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var typesTask = BusinessService.GetBusinessTypes();
            var existing = await BusinessService.GetOneById(Id);
            
            BusinessTypes = await typesTask;

            if (existing is not null)
            {
                Model = new BusinessAddModel
                {
                    Name = existing.Name,
                    Address = existing.Address,
                    Description = existing.Description,
                    Contact = existing.Contact,
                    BusinessTypeId = BusinessTypes?.FirstOrDefault(t => t.Name == existing.BusinessTypeName)?.Id ?? 1
                };
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Eroare la încărcarea datelor: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (Model is null) return;

        try
        {
            var success = await BusinessService.EditAsync(Id, Model);
            if (success)
            {
                NavigationManager.NavigateTo($"/business/{Id}");
            }
            else
            {
                ErrorMessage = "Eroare la salvarea afacerii pe server.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Excepție la salvare: {ex.Message}";
        }
    }

    private async Task HandleDelete()
    {
        try
        {
            var success = await BusinessService.DeleteAsync(Id);
            if (success)
            {
                NavigationManager.NavigateTo("/");
            }
            else
            {
                ErrorMessage = "Eroare la ștergerea afacerii.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Excepție la ștergere: {ex.Message}";
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo($"/business/{Id}");
    }
}