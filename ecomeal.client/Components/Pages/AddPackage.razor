@page "/business/{BusinessId:int}/package/add"
@using EcoMeal.Client.Models
@using EcoMeal.Client.Services
@using MudBlazor
@inject PackageService PackageService
@inject NavigationManager NavigationManager

<PageTitle>Add Package</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               Color="Color.Dark" Class="mb-4"
               OnClick="NavigateBack">
        Înapoi la afacere
    </MudButton>

    <MudPaper Class="pa-8 rounded-xl" Elevation="0" Style="border: 1px solid #e0e0e0; background-color: #ffffff;">
        <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 800; color: #212529;">Adaugă Pachet</MudText>
        <MudText Typo="Typo.body2" Class="mb-6" Style="color: #6b7280;">Creează un nou pachet surpriză pentru clienți.</MudText>

        <EditForm Model="PackageAddModel" OnValidSubmit="AddPackageToBusiness">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="PackageAddModel.Name" Label="Nume Pachet" Variant="Variant.Outlined" Class="mb-4" Required="true" />
            <MudTextField @bind-Value="PackageAddModel.Description" Label="Descriere" Variant="Variant.Outlined" Lines="3" Class="mb-4" />
            
            <MudNumericField @bind-Value="PackageAddModel.Price" Label="Preț" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" Class="mb-4" />

            <MudGrid Spacing="2" Class="mb-4">
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Class="mb-1">Pickup Start</MudText>
                    <InputDate @bind-Value="PackageAddModel.StartPickup" Type="InputDateType.DateTimeLocal" class="form-control" />
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Class="mb-1">Pickup End</MudText>
                    <InputDate @bind-Value="PackageAddModel.EndPickup" Type="InputDateType.DateTimeLocal" class="form-control" />
                </MudItem>
            </MudGrid>

            <MudSelect @bind-Value="PackageAddModel.PackageTypeId" Label="Tip Pachet" Variant="Variant.Outlined" Class="mb-6">
                @if (PackageTypes is not null)
                {
                    @foreach (var type in PackageTypes)
                    {
                        <MudSelectItem Value="type.Id">@type.Name</MudSelectItem>
                    }
                }
            </MudSelect>

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Size="Size.Large">
                Creează Pachetul
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public int BusinessId { get; set; }

    public PackageAddModel PackageAddModel { get; set; } = new()
    {
        Name = string.Empty,
        Description = string.Empty,
        Price = 0,
        PackageTypeId = 1,
        StartPickup = DateTime.Now,
        EndPickup = DateTime.Now.AddHours(2)
    };

    private List<PackageTypeModel>? PackageTypes;

    protected override async Task OnInitializedAsync()
    {
        PackageTypes = await PackageService.GetPackageTypes();
    }

    public async Task AddPackageToBusiness()
{
    try 
    {
        // 1. Verificam daca modelul este valid (obligatoriu)
        var result = await PackageService.AddAsync(BusinessId, PackageAddModel);
        
        if (result)
        {
            NavigationManager.NavigateTo($"/business/{BusinessId}");
        }
        else
        {
            // Aici poti adauga un Snackbar de eroare (MudBlazor)
            Console.WriteLine("Eroare la salvare: Serviciul a returnat false.");
        }
    }
    catch (Exception ex)
    {
        // Aceasta va afisa eroarea in consola browserului (F12)
        Console.WriteLine($"Exceptie fatala: {ex.Message}");
    }
}

    private void NavigateBack() => NavigationManager.NavigateTo($"/business/{BusinessId}");
}