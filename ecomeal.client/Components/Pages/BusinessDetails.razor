@page "/business/{Id:int}"
@using EcoMeal.Client.Models
@using EcoMeal.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject BusinessService BusinessService
@inject PackageService PackageService
@inject OrderService OrderService
@inject ISnackbar Snackbar

@if (Business == null)
{
    <div class="d-flex justify-content-center mt-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Success" />
    </div>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
        <MudPaper Class="pa-8 rounded-xl shadow-sm mb-6" Elevation="0">
            <div style="background-color: #35c022; color: white; display: inline-block; padding: 4px 16px; border-radius: 20px; font-weight: 600; margin-bottom: 16px;">
                @Business.BusinessTypeName
            </div>
            
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: #212529;">@Business.Name</MudText>
            <MudText Typo="Typo.body1" Class="mt-2" Style="color: #6c757d;">@Business.Description</MudText>
            
            <MudStack Row="true" Class="mt-6" Spacing="4">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Success" />
                <MudText>@Business.Address</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Success" Class="ms-4" />
                <MudText>@Business.Contact</MudText>
            </MudStack>
        </MudPaper>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <MudText Typo="Typo.h5" Style="font-weight: 700;">Pachete Disponibile</MudText>
            
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" Href="@("/business/" + Id + "/package/add")">
                        Adaugă Pachet
                    </MudButton>
                </Authorized>
            </AuthorizeView>
        </div>

        <MudGrid>
            @if (Business.Packages != null && Business.Packages.Any())
            {
                @foreach (var pkg in Business.Packages)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="h-100 d-flex flex-column rounded-xl border-0" Style="background: linear-gradient(135deg, #35c022 0%, #4cae4c 100%); color: white;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="font-weight: 700; color: white;">@pkg.Name</MudText>
                                    <MudText Typo="Typo.body2" Style="color: #e8f5e9;">@pkg.PackageTypeName</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <div style="background-color: white; color: #35c022; padding: 4px 12px; border-radius: 20px; font-weight: bold; margin-top: 8px;">
                                        @pkg.Price Lei
                                    </div>
                                </CardHeaderActions>
                            </MudCardHeader>
                            
                            <MudCardContent Class="flex-grow-1">
                                <MudText Typo="Typo.body2" Class="mb-3" Style="color: #f1f8e9;">@pkg.Description</MudText>
                                
                                <div style="font-size: 0.85rem; background-color: rgba(255, 255, 255, 0.2); padding: 10px; border-radius: 8px;">
                                    <div><strong style="color: white;">Start:</strong> @pkg.PickUpStart.ToString("dd/MM/yyyy HH:mm")</div>
                                    <div class="mt-1"><strong style="color: white;">End:</strong> @pkg.PickUpEnd.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </MudCardContent>
                            
                            <MudCardActions Class="justify-end pb-4 pe-4">
                                <AuthorizeView Roles="Admin">
                                    <Authorized Context="adminAuth">
                                        <MudButton Variant="Variant.Filled" Style="background-color: white; color: #35c022; font-weight: 600;" Size="Size.Small" Href="@("/business/" + Id + "/editPackage/" + pkg.Id)" Class="me-2">Edit</MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="@(() => HandleDeletePackage(pkg.Id))">Delete</MudButton>
                                    </Authorized>
                                </AuthorizeView>

                                <AuthorizeView Roles="User">
                                    <Authorized Context="userAuth">
                                        <MudButton Variant="Variant.Filled" Style="background-color: white; color: #35c022; font-weight: 600;" Size="Size.Small" OnClick="@(() => HandlePlaceOrder(pkg.Id))">
                                            Rezervă
                                        </MudButton>
                                    </Authorized>
                                </AuthorizeView>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Nu există pachete adăugate momentan pentru această afacere.</MudAlert>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter] public int Id { get; set; }
    private BusinessDetailsModel? Business;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        Business = await BusinessService.GetOneById(Id);
        if (Business != null)
        {
            Business.Packages = await PackageService.GetByBusinessId(Id);
        }
    }

    private async Task HandleDeletePackage(int packageId)
    {
        var success = await PackageService.DeleteAsync(Id, packageId);
        if (success)
        {
            Snackbar.Add("Pachetul a fost șters cu succes!", Severity.Success);
            await LoadDataAsync(); 
        }
        else
        {
            Snackbar.Add("Eroare la ștergerea pachetului.", Severity.Error);
        }
    }

    private async Task HandlePlaceOrder(int packageId)
    {
        try
        {
            var success = await OrderService.PlaceOrderAsync(packageId);
            if (success)
            {
                Snackbar.Add("Comanda a fost plasată cu succes!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Eroare: API-ul a respins comanda (posibil 401 Unauthorized sau 500).", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Excepție: {ex.Message}", Severity.Error);
        }
    }
}