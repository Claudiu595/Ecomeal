@page "/business/{BusinessId:int}/editPackage/{PackageId:int}"
@using EcoMeal.Client.Models
@using EcoMeal.Client.Services
@using MudBlazor

<PageTitle>Editare Pachet</PageTitle>

<style>
    .solid-dropdown-popover {
        background-color: #ffffff !important;
        border: 1px solid #e0e0e0;
        box-shadow: 0px 4px 12px rgba(0,0,0,0.15) !important;
    }
    .solid-dropdown-popover .mud-list-item-text {
        color: #212529 !important;
    }
    .solid-dropdown-popover .mud-list-item:hover {
        background-color: #f1f1f1 !important;
    }
</style>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
}

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               Style="text-transform: none; color: #35c022; font-weight: 600; margin-bottom: 1rem;"
               OnClick="NavigateBack">
        Înapoi la afacere
    </MudButton>

    @if (IsLoading)
    {
        <MudPaper Class="pa-8 rounded-xl d-flex justify-center" Elevation="0" Style="border: 1px solid #f0f0f0;">
            <MudProgressCircular Indeterminate="true" Color="Color.Success" />
        </MudPaper>
    }
    else if (PackageEditModel is null)
    {
        <MudAlert Severity="Severity.Warning">Pachetul nu a fost găsit.</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-8 rounded-xl shadow-sm" Elevation="0" Style="border: 1px solid #e0e0e0; background-color: #ffffff;">
            <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 800; color: #212529;">Editare Pachet</MudText>
            <MudText Typo="Typo.body2" Class="mb-6" Style="color: #6b7280;">Actualizează detaliile pachetului mai jos.</MudText>

            <EditForm Model="PackageEditModel" OnValidSubmit="SaveChanges">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="PackageEditModel.Name"
                              Label="Nume Pachet"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Required="true"
                              RequiredError="Numele este obligatoriu" />

                <MudTextField @bind-Value="PackageEditModel.Description"
                              Label="Descriere"
                              Variant="Variant.Outlined"
                              Lines="3"
                              Class="mb-4" />

                <MudNumericField @bind-Value="PackageEditModel.Price"
                                 Label="Preț"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                 Min="0.01"
                                 Class="mb-4" />

                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="PackageEditModel.StartPickup" 
                                      Format="s" 
                                      InputType="InputType.DateTimeLocal" 
                                      Label="Pickup Start" 
                                      Variant="Variant.Outlined" 
                                      Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="PackageEditModel.EndPickup" 
                                      Format="s" 
                                      InputType="InputType.DateTimeLocal" 
                                      Label="Pickup End" 
                                      Variant="Variant.Outlined" 
                                      Required="true" />
                    </MudItem>
                </MudGrid>

                <MudSelect @bind-Value="PackageEditModel.PackageTypeId"
                           Label="Tip Pachet"
                           Variant="Variant.Outlined"
                           Class="mb-6"
                           Required="true"
                           RequiredError="Te rog selectează un tip de pachet"
                           AnchorOrigin="Origin.BottomCenter"
                           PopoverClass="solid-dropdown-popover">
                    @if (PackageTypes is not null)
                    {
                        @foreach (var type in PackageTypes)
                        {
                            <MudSelectItem Value="type.Id">@type.Name</MudSelectItem>
                        }
                    }
                </MudSelect>

                <MudStack Row="true" Spacing="3">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Success"
                               Style="font-weight: 700; flex: 1;"
                               Size="Size.Large">
                        Salvează
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Style="font-weight: 600;"
                               Size="Size.Large"
                               OnClick="DeletePackage">
                        Șterge
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int BusinessId { get; set; }

    [Parameter]
    public int PackageId { get; set; }

    [Inject]
    public required PackageService PackageService { get; set; }
    
    [Inject]
    public required NavigationManager NavigationManager { get; set; }

    private PackageAddModel? PackageEditModel;
    private List<PackageTypeModel>? PackageTypes;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var packageTypesTask = PackageService.GetPackageTypes();
            var packageTask = PackageService.GetById(BusinessId, PackageId);

            PackageTypes = await packageTypesTask;
            var existing = await packageTask;

            if (existing is not null)
            {
                PackageEditModel = new PackageAddModel
                {
                    Name = existing.Name,
                    Description = existing.Description ?? string.Empty,
                    Price = (double)existing.Price,
                    StartPickup = existing.PickUpStart,
                    EndPickup = existing.PickUpEnd,
                    PackageTypeId = PackageTypes?.FirstOrDefault(t => t.Name == existing.PackageTypeName)?.Id ?? 1
                };
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Eroare API: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveChanges()
    {
        if (PackageEditModel is null) return;

        var success = await PackageService.EditAsync(BusinessId, PackageId, PackageEditModel);
        if (success)
        {
            NavigationManager.NavigateTo($"/business/{BusinessId}");
        }
        else
        {
            ErrorMessage = "A apărut o eroare la salvarea modificărilor.";
        }
    }

    private async Task DeletePackage()
    {
        var success = await PackageService.DeleteAsync(BusinessId, PackageId);
        if (success)
        {
            NavigationManager.NavigateTo($"/business/{BusinessId}");
        }
        else
        {
            ErrorMessage = "A apărut o eroare la ștergerea pachetului.";
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo($"/business/{BusinessId}");
    }
}